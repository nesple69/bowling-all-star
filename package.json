{
  "name": "bowling-management-app",
  "version": "1.0.0",
  "description": "Bowling Association Management Web App",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "client": "npm run dev --workspace=client",
    "server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run client\" \"npm run server\"",
    "build": "npm run build --workspaces",
    "install-all": "npm install",
    "postinstall": "npm run prisma:generate --workspace=server"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "autoprefixer": "^10.4.24",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18"
  }
}